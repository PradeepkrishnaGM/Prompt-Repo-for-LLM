{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClassifyTicketOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["category", "priority", "sentiment", "needs_escalation", "reason"],
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "billing",
        "technical_issue",
        "account_access",
        "feature_request",
        "general_question",
        "other"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "sentiment": {
      "type": "string",
      "enum": ["negative", "neutral", "positive", "mixed"]
    },
    "needs_escalation": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
